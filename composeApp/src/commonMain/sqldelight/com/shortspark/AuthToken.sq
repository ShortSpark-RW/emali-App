CREATE TABLE AuthToken (
    id INTEGER NOT NULL PRIMARY KEY,
    userId TEXT NOT NULL,
    accessToken TEXT NOT NULL,
    refreshToken TEXT NOT NULL,
    expiresAt TEXT,
    FOREIGN KEY (userId) REFERENCES User(id) ON DELETE CASCADE
);

insertToken:
INSERT OR REPLACE INTO AuthToken(id, userId, accessToken, refreshToken, expiresAt) VALUES (0, ?, ?, ?, ?);

getToken:
SELECT * FROM AuthToken WHERE id = 0;

clearToken:
DELETE FROM AuthToken WHERE id = 0;
